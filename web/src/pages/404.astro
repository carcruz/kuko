---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Página no encontrada" noIndex>
  <div class="max-w-7xl mx-auto px-6 py-32 text-center">
    <p class="text-8xl font-black mb-4">404</p>
    <p class="text-xl text-[#6B6B6B] mb-8">Esta página no existe.</p>
    <a href="/" class="inline-block border-2 border-black px-8 py-4 font-semibold text-sm uppercase tracking-wide hover:bg-black hover:text-white transition-colors">
      Volver al inicio
    </a>
  </div>
</BaseLayout>
