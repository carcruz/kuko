---
export const prerender = true

import BaseLayout from '../layouts/BaseLayout.astro'
import { reader } from '../lib/reader'

const allDatasets = await reader.collections.datasets.all()

const datasets = await Promise.all(
  allDatasets
    .sort((a, b) => (b.entry.lastUpdated ?? '').localeCompare(a.entry.lastUpdated ?? ''))
    .map(async (d) => {
      const cat = d.entry.category
        ? await reader.collections.categories.read(d.entry.category)
        : null
      return {
        slug: d.slug,
        title: d.entry.title,
        description: d.entry.description,
        source: d.entry.source,
        lastUpdated: d.entry.lastUpdated,
        downloadUrl: d.entry.downloadUrl,
        category: cat ? { title: cat.title, color: cat.color } : null,
        tags: d.entry.tags,
      }
    })
)
---

<BaseLayout
  title="Datos abiertos"
  description="Datasets descargables producidos por KUKO a partir de solicitudes SAIP y fuentes oficiales."
>
  <section class="border-b border-black">
    <div class="max-w-7xl mx-auto px-6 py-12">
      <p class="text-[11px] uppercase tracking-widest text-[#6B6B6B] mb-3">Datos abiertos</p>
      <h1 class="text-4xl md:text-5xl font-black tracking-tight">Datos</h1>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-6 py-12">
    {datasets.length === 0 ? (
      <p class="text-[#6B6B6B] py-16 text-center">Próximamente — los datasets aparecerán aquí.</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-[#E8E8E8] border border-[#E8E8E8]">
        {datasets.map((ds) => (
          <div class="bg-white p-6 flex flex-col gap-3 hover:bg-[#FAFAFA] transition-colors">
            {ds.category && (
              <span class="text-[11px] uppercase tracking-widest font-semibold" style={`color: ${ds.category.color ?? '#6B6B6B'}`}>
                {ds.category.title}
              </span>
            )}
            <h2 class="font-bold text-base leading-snug">{ds.title}</h2>
            {ds.description && (
              <p class="text-sm text-[#444] leading-relaxed line-clamp-3">{ds.description}</p>
            )}
            {ds.tags && ds.tags.length > 0 && (
              <div class="flex flex-wrap gap-1.5">
                {ds.tags.map((tag) => (
                  <span class="text-[11px] border border-[#E8E8E8] px-2 py-0.5 text-[#6B6B6B]">{tag}</span>
                ))}
              </div>
            )}
            <div class="mt-auto pt-3 border-t border-[#F0F0F0] flex items-center justify-between">
              <div class="text-[11px] text-[#6B6B6B] flex flex-col gap-0.5">
                {ds.source && <span>{ds.source}</span>}
                {ds.lastUpdated && (
                  <span>
                    {new Date(ds.lastUpdated).toLocaleDateString('es-CR', { year: 'numeric', month: 'long' })}
                  </span>
                )}
              </div>
              {ds.downloadUrl && (
                <a
                  href={ds.downloadUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-xs uppercase tracking-wide border border-black px-3 py-1.5 hover:bg-black hover:text-white transition-colors"
                >
                  Descargar
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
