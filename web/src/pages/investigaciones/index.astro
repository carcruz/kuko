  { name: 'Salud Pública', slug: 'salud', color: '#E85D75' },
  { name: 'Educación', slug: 'educacion', color: '#5B8DEE' },
  { name: 'Economía & Finanzas', slug: 'economia', color: '#F5A623' },
  { name: 'Política & Gobernanza', slug: 'politica', color: '#7B68EE' },
  { name: 'Ambiente & Sostenibilidad', slug: 'ambiente', color: '#50C878' },
  { name: 'Urbanismo & Vivienda', slug: 'urbanismo', color: '#FF6B35' },
  { name: 'Tecnología & Innovación', slug: 'tecnologia', color: '#9B59B6' },
  { name: 'Justicia & Seguridad', slug: 'justicia', color: '#34495E' },
]

const TYPES = [
  { label: 'Análisis Profundo', value: 'analisis' },
  { label: 'Contexto Internacional', value: 'contexto' },
  { label: 'Análisis de Datos', value: 'datos' },
  { label: 'Explicador', value: 'explicador' },
  { label: 'Propuesta Concreta', value: 'propuesta' },
]

const ARTICLES = [
  {
    slug: 'sistema-numeracion-buses',
    title: 'Sistema de Numeración de Buses: El Caos que Pagamos Cada Día',
    category: 'Movilidad & Transporte', categorySlug: 'movilidad', categoryColor: '#00A896',
    type: 'Análisis Profundo', typeValue: 'analisis', readTime: '25 min', date: 'Ene 2025',
    excerpt: 'Con 476 rutas sin lógica geográfica, Costa Rica tiene uno de los sistemas de transporte más confusos de la región. Analizamos los datos y presentamos opciones reales.',
  },
  {
    slug: null,
    title: 'Listas de Espera CCSS: +68% en Cinco Años',
    category: 'Salud Pública', categorySlug: 'salud', categoryColor: '#E85D75',
    type: 'Análisis Profundo', typeValue: 'analisis', readTime: '18 min', date: 'Ene 2025',
    excerpt: 'Las listas de espera quirúrgicas han aumentado de 42,000 a 68,000 personas desde 2020. Causas, comparación regional y opciones.',
  },
  {
    slug: null,
    title: 'Chile y su Transantiago: Lecciones para Costa Rica',
    category: 'Movilidad & Transporte', categorySlug: 'movilidad', categoryColor: '#00A896',
    type: 'Contexto Internacional', typeValue: 'contexto', readTime: '12 min', date: 'Dic 2024',
    excerpt: '¿Qué podemos aprender de la mayor reforma de transporte público en la historia de Chile? Un análisis de viabilidad para CR.',
  },
  {
    slug: null,
    title: 'Canasta Básica: Evolución del Costo de Vida 2020–2025',
    category: 'Economía & Finanzas', categorySlug: 'economia', categoryColor: '#F5A623',
    type: 'Análisis de Datos', typeValue: 'datos', readTime: '8 min', date: 'Dic 2024',
    excerpt: 'Cinco años de datos sobre el costo de la canasta básica y su impacto diferenciado por nivel de ingreso y región.',
  },
  {
    slug: null,
    title: '¿Qué son las Pruebas PISA y Por Qué Importan?',
    category: 'Educación', categorySlug: 'educacion', categoryColor: '#5B8DEE',
    type: 'Explicador', typeValue: 'explicador', readTime: '10 min', date: 'Nov 2024',
    excerpt: 'Desmitificamos las evaluaciones internacionales de educación y lo que realmente dicen sobre el sistema educativo costarricense.',
  },
  {
    slug: null,
    title: 'Gestión de Residuos en San José: El Problema que no Vemos',
    category: 'Ambiente & Sostenibilidad', categorySlug: 'ambiente', categoryColor: '#50C878',
    type: 'Análisis Profundo', typeValue: 'analisis', readTime: '20 min', date: 'Nov 2024',
    excerpt: 'El 34% de los residuos sólidos de San José no llegan a reciclaje. Qué hacen otras ciudades latinoamericanas.',
  },
  {
    slug: null,
    title: 'Transparencia Presupuestaria: CR vs. América Latina',
    category: 'Política & Gobernanza', categorySlug: 'politica', categoryColor: '#7B68EE',
    type: 'Análisis de Datos', typeValue: 'datos', readTime: '14 min', date: 'Oct 2024',
    excerpt: 'Comparamos los índices de transparencia fiscal de Costa Rica con 10 países de la región usando datos del FMI.',
  },
  {
    slug: null,
    title: 'Crisis de Vivienda en el GAM: Datos, Causas y Opciones',
    category: 'Urbanismo & Vivienda', categorySlug: 'urbanismo', categoryColor: '#FF6B35',
    type: 'Análisis Profundo', typeValue: 'analisis', readTime: '22 min', date: 'Oct 2024',
    excerpt: 'El déficit habitacional en la Gran Área Metropolitana supera las 100,000 unidades. Evidencia y alternativas.',
  },
  {
    slug: null,
    title: 'Brecha Digital en Costa Rica: ¿Quién queda afuera?',
    category: 'Tecnología & Innovación', categorySlug: 'tecnologia', categoryColor: '#9B59B6',
    type: 'Análisis de Datos', typeValue: 'datos', readTime: '11 min', date: 'Sep 2024',
    excerpt: 'El 28% de los hogares costarricenses no tienen acceso a internet de banda ancha. Los factores geográficos y económicos detrás.',
  },
  {
    slug: null,
    title: 'Amsterdam y la Movilidad Activa: ¿Qué podría adaptar CR?',
    category: 'Movilidad & Transporte', categorySlug: 'movilidad', categoryColor: '#00A896',
    type: 'Contexto Internacional', typeValue: 'contexto', readTime: '13 min', date: 'Sep 2024',
    excerpt: '800 km de ciclovías y el 63% de viajes activos. Qué elementos del modelo neerlandés son trasladables al contexto costarricense.',
  },
  {
    slug: null,
    title: 'Hacinamiento Penitenciario: Más Allá de la Capacidad',
    category: 'Justicia & Seguridad', categorySlug: 'justicia', categoryColor: '#34495E',
    type: 'Análisis Profundo', typeValue: 'analisis', readTime: '19 min', date: 'Ago 2024',
    excerpt: 'El 42% de hacinamiento en centros penales no es solo un problema de espacio. Reincidencia, factores de fondo y comparación regional.',
  },
  {
    slug: null,
    title: 'Salario Mínimo: Historia, Impacto y Debate en CR',
    category: 'Economía & Finanzas', categorySlug: 'economia', categoryColor: '#F5A623',
    type: 'Explicador', typeValue: 'explicador', readTime: '9 min', date: 'Ago 2024',
    excerpt: 'El sistema de salario mínimo costarricense en perspectiva regional y el debate técnico sobre su impacto en el empleo.',
  },
]
---

<BaseLayout title="Investigaciones — KUKO" description="Análisis basados en datos para entender los desafíos de Costa Rica.">

  {/* ── Page header ── */}
  <div class="border-b border-black">
    <div class="max-w-7xl mx-auto px-6 py-14">
      <p class="text-[11px] uppercase tracking-[0.1em] text-[#7A7A7A] mb-3">Archivo</p>
      <h1 class="text-5xl md:text-6xl font-black tracking-tight leading-none mb-4">Investigaciones</h1>
      <p class="text-[#2D2D2D] text-lg max-w-xl">
        Análisis basados en datos para entender los desafíos de Costa Rica.
      </p>
    </div>
  </div>

  {/* ── Filters ── */}
  <div class="max-w-7xl mx-auto px-6 pt-8 pb-6 border-b border-[#E8E8E8]">

    {/* Search bar */}
    <div class="relative max-w-2xl mb-6">
      <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-[#7A7A7A]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <circle cx="11" cy="11" r="8" /><path d="m21 21-4.35-4.35" />
      </svg>
      <input
        id="search-input"
        type="text"
        placeholder="Buscar por tema, categoría o palabra clave…"
        class="w-full h-[52px] pl-11 pr-10 border border-black text-sm placeholder:text-[#7A7A7A] focus:outline-none focus:border-[#00A896] bg-white"
      />
    </div>

    {/* Category pills */}
    <div class="flex items-center gap-2 overflow-x-auto pb-1 mb-3">
      <svg class="w-3.5 h-3.5 text-[#7A7A7A] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <line x1="4" x2="20" y1="6" y2="6"/><line x1="8" x2="16" y1="12" y2="12"/><line x1="12" x2="12" y1="18" y2="18"/>
      </svg>
      <button
        class="filter-cat shrink-0 h-8 px-3.5 text-[12px] font-medium uppercase tracking-wide border bg-black text-white border-black transition-colors"
        data-cat=""
      >
        Todas
      </button>
      {CATEGORIES.map(({ name, slug, color }) => (
        <button
          class="filter-cat shrink-0 h-8 px-3.5 text-[12px] font-medium border bg-white text-black border-[#E8E8E8] hover:border-black transition-colors flex items-center gap-1.5"
          data-cat={slug}
        >
          <span class="w-1.5 h-1.5 rounded-full shrink-0" style={`background:${color}`} />
          {name}
        </button>
      ))}
    </div>

    {/* Type pills */}
    <div class="flex items-center gap-2 overflow-x-auto pb-1">
      <span class="w-3.5 h-3.5 shrink-0" />
      {TYPES.map(({ label, value }) => (
        <button
          class="filter-type shrink-0 h-7 px-3 text-[11px] border border-[#E8E8E8] text-[#6B6B6B] bg-white hover:text-black hover:border-[#BDBDBD] transition-colors"
          data-type={value}
        >
          {label}
        </button>
      ))}
    </div>
  </div>

  {/* ── Results header ── */}
  <div class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between border-b border-[#E8E8E8]">
    <p class="text-[13px] text-[#7A7A7A]" id="results-count">{ARTICLES.length} investigaciones</p>
    <button id="clear-filters" class="hidden text-[12px] text-[#7A7A7A] hover:text-black transition-colors underline underline-offset-2">
      Limpiar filtros
    </button>
  </div>

  {/* ── Grid ── */}
  <div class="max-w-7xl mx-auto px-6 py-10">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6" id="articles-grid">
      {ARTICLES.map((article) => (
        <div
          class="article-item border border-[#E8E8E8] p-6 flex flex-col hover:border-black hover:shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:-translate-y-0.5 transition-all duration-200 group"
          data-cat={article.categorySlug}
          data-type={article.typeValue}
          data-title={article.title.toLowerCase()}
          data-excerpt={article.excerpt.toLowerCase()}
          data-category-name={article.category.toLowerCase()}
        >
          {/* Category + type */}
          <div class="flex items-center gap-2 mb-4 flex-wrap">
            <span class="flex items-center gap-1.5">
              <span class="w-1.5 h-1.5 rounded-full shrink-0" style={`background:${article.categoryColor}`} />
              <span class="text-[11px] font-medium uppercase tracking-[0.07em] text-black">{article.category}</span>
            </span>
            <span class="text-[#E8E8E8]">·</span>
            <span
              class="text-[11px] uppercase tracking-[0.06em] px-2 py-0.5"
              style={`background:${article.categoryColor}18; color:${article.categoryColor}`}
            >
              {article.type}
            </span>
          </div>

          {/* Title */}
          <h3 class="text-[17px] font-black tracking-tight leading-snug mb-3 flex-none">
            {article.title}
          </h3>

          {/* Excerpt */}
          <p class="text-[14px] text-[#6B6B6B] leading-relaxed mb-5 flex-1 line-clamp-3">
            {article.excerpt}
          </p>

          {/* Footer */}
          <div class="flex items-center justify-between pt-4 border-t border-[#F0F0F0] mt-auto">
            <span class="text-[12px] text-[#7A7A7A]">{article.date} · {article.readTime}</span>
            {article.slug ? (
              <a href={`/articulo/${article.slug}`} class="text-[12px] text-[#00A896] hover:underline font-medium flex items-center gap-1">
                Leer
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M9 18l6-6-6-6" />
                </svg>
              </a>
            ) : (
              <svg class="w-4 h-4 text-[#BDBDBD] group-hover:text-black transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M9 18l6-6-6-6" />
              </svg>
            )}
          </div>
        </div>
      ))}
    </div>

    <div id="empty-state" class="hidden text-center py-24 border border-[#E8E8E8]">
      <p class="text-4xl font-black tracking-tight mb-3 text-[#E8E8E8]">∅</p>
      <p class="text-lg font-semibold mb-2">Sin resultados</p>
      <p class="text-sm text-[#7A7A7A] mb-6 max-w-xs mx-auto">
        No encontramos investigaciones con esos filtros.
      </p>
      <button id="clear-filters-empty" class="px-5 py-2.5 border border-black text-sm hover:bg-black hover:text-white transition-colors">
        Limpiar filtros
      </button>
    </div>
  </div>

</BaseLayout>

<script>
  const items = document.querySelectorAll<HTMLElement>('.article-item')
  const grid = document.getElementById('articles-grid')!
  const emptyState = document.getElementById('empty-state')!
  const countEl = document.getElementById('results-count')!
  const clearBtn = document.getElementById('clear-filters')!
  const clearBtnEmpty = document.getElementById('clear-filters-empty')!
  const searchInput = document.getElementById('search-input') as HTMLInputElement
  const catBtns = document.querySelectorAll<HTMLButtonElement>('.filter-cat')
  const typeBtns = document.querySelectorAll<HTMLButtonElement>('.filter-type')

  let activeCat = ''
  let activeType = ''
  let query = ''

  function applyFilters() {
    const q = query.toLowerCase()
    let visible = 0
    items.forEach((item) => {
      const matchCat = !activeCat || item.dataset.cat === activeCat
      const matchType = !activeType || item.dataset.type === activeType
      const matchSearch = !q || [item.dataset.title, item.dataset.excerpt, item.dataset.categoryName].some(s => s?.includes(q))
      const show = matchCat && matchType && matchSearch
      item.style.display = show ? '' : 'none'
      if (show) visible++
    })

    const total = items.length
    countEl.textContent = visible === total
      ? `${total} investigaciones`
      : `${visible} resultado${visible !== 1 ? 's' : ''}`

    const hasFilters = activeCat || activeType || q
    clearBtn.classList.toggle('hidden', !hasFilters)
    emptyState.classList.toggle('hidden', visible > 0)
    grid.classList.toggle('hidden', visible === 0)
  }

  function updateCatStyles() {
    catBtns.forEach((btn) => {
      const active = btn.dataset.cat === activeCat
      btn.classList.toggle('bg-black', active)
      btn.classList.toggle('text-white', active)
      btn.classList.toggle('border-black', active)
      btn.classList.toggle('bg-white', !active)
      btn.classList.toggle('text-black', !active)
      btn.classList.toggle('border-[#E8E8E8]', !active)
    })
  }

  function updateTypeStyles() {
    typeBtns.forEach((btn) => {
      const active = btn.dataset.type === activeType
      btn.classList.toggle('bg-black', active)
      btn.classList.toggle('text-white', active)
      btn.classList.toggle('border-black', active)
      btn.classList.toggle('text-[#6B6B6B]', !active)
      btn.classList.toggle('border-[#E8E8E8]', !active)
    })
  }

  function clearAll() {
    activeCat = ''
    activeType = ''
    query = ''
    searchInput.value = ''
    updateCatStyles()
    updateTypeStyles()
    applyFilters()
  }

  catBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeCat = activeCat === btn.dataset.cat ? '' : (btn.dataset.cat ?? '')
      if (btn.dataset.cat === '') activeCat = ''
      updateCatStyles()
      applyFilters()
    })
  })

  typeBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeType = activeType === btn.dataset.type ? '' : (btn.dataset.type ?? '')
      updateTypeStyles()
      applyFilters()
    })
  })

  searchInput.addEventListener('input', () => {
    query = searchInput.value
    applyFilters()
  })

  clearBtn.addEventListener('click', clearAll)
  clearBtnEmpty.addEventListener('click', clearAll)
</script>
